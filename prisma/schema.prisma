generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  comments      Comment[]
  follows       Follow[]
  mangas        Manga[]
  ratings       Rating[]
  readHistory   ReadHistory[]
  sessions      Session[]
  role      String   @default("user")
  emailVerifyToken  String?

}

model Manga {
  id          String        @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  genre       String[]
  status      String        @default("ongoing")
  views       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  authorId    String
  chapters    Chapter[]
  comments    Comment[]
  follows     Follow[]
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  ratings     Rating[]
  readHistory ReadHistory[]
}

model Chapter {
  id          String        @id @default(cuid())
  title       String
  chapterNum  Float
  pages       String[]
  views       Int           @default(0)
  createdAt   DateTime      @default(now())
  mangaId     String
  manga       Manga         @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  comments    Comment[]
  readHistory ReadHistory[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  userId    String
  mangaId   String?
  chapterId String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  manga     Manga?   @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Rating {
  id      String @id @default(cuid())
  score   Float
  userId  String
  mangaId String
  manga   Manga  @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Follow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  mangaId   String
  manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
}

model ReadHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @updatedAt
  userId    String
  mangaId   String
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  manga     Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
}
